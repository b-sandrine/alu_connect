rules_version = '2';

// See docs/firestore-schema.md for the full collection design rationale.
// NOT DEPLOYED YET — review before running `firebase deploy --only firestore:rules`.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function unchanged(field) {
      return !(field in request.resource.data) ||
        !(field in resource.data) ||
        request.resource.data[field] == resource.data[field];
    }

    // users/{uid} — auth-linked identity + role gate for the whole app.
    // Anyone signed in can read (display-name lookups on opportunities/
    // applications); only the owner can write, and role/email/createdAt
    // are immutable after creation.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
        && unchanged('role')
        && unchanged('email')
        && unchanged('createdAt');
      allow delete: if false;
    }

    // opportunities/{id} — postings browsed by every student, managed only
    // by the owning startup.
    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.startupId == request.auth.uid
        && userRole(request.auth.uid) == 'startup';
      allow update, delete: if isSignedIn()
        && resource.data.startupId == request.auth.uid;
    }

    // applications/{id} — the join between a student and an opportunity,
    // now tracking a full status pipeline (applied -> screening ->
    // interview -> technicalAssessment -> offer -> accepted/rejected).
    // Strict stage-adjacency validation lives in the app (ApplicationController),
    // not here — these rules are the coarser security backstop: only the
    // right actor can write, and terminal states can't be reopened.
    match /applications/{applicationId} {
      allow read: if isSignedIn()
        && (resource.data.applicantId == request.auth.uid
            || resource.data.startupId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.applicantId == request.auth.uid
        && userRole(request.auth.uid) == 'student'
        && get(/databases/$(database)/documents/opportunities/$(request.resource.data.opportunityId)).data.isActive == true;

      // Startup: can move a non-terminal application through the pipeline
      // (or reject it) but can't touch the applicant's original content.
      allow update: if isSignedIn()
        && resource.data.startupId == request.auth.uid
        && resource.data.status != 'accepted'
        && resource.data.status != 'rejected'
        && unchanged('applicantId')
        && unchanged('opportunityId')
        && unchanged('coverLetter')
        && unchanged('appliedAt');

      // Applicant: can only respond to their own offer (accept or decline).
      allow update: if isSignedIn()
        && resource.data.applicantId == request.auth.uid
        && resource.data.status == 'offer'
        && (request.resource.data.status == 'accepted'
            || request.resource.data.status == 'rejected')
        && unchanged('opportunityId')
        && unchanged('startupId')
        && unchanged('coverLetter')
        && unchanged('appliedAt');

      allow delete: if false;
    }

    // startup_profiles/{id} — public-facing company info, separate from the
    // private users/ auth record so it can be read by anyone browsing.
    match /startup_profiles/{profileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && userRole(request.auth.uid) == 'startup';
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    // bookmarks/{uid} — one array-in-doc per user; never shared.
    match /bookmarks/{userId} {
      allow read, write: if isSelf(userId);
    }

    // conversations/{id} — 1:1 thread between a student and a startup.
    // Doc ID is deterministic (sorted participant UIDs joined with '_'),
    // not auto-generated, so participantIds is derivable from the ID itself;
    // the check below still guards against writes/reads by anyone else.
    match /conversations/{conversationId} {
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;

      allow delete: if false;

      // messages/{id} — immutable once sent; only a participant of the
      // parent conversation can read, and only the sender (who must also be
      // a participant) can create.
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        allow update, delete: if false;
      }
    }
  }
}
