rules_version = '2';

// See docs/firestore-schema.md for the full collection design rationale.
// NOT DEPLOYED YET — review before running `firebase deploy --only firestore:rules`.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function unchanged(field) {
      return !(field in request.resource.data) ||
        !(field in resource.data) ||
        request.resource.data[field] == resource.data[field];
    }

    // users/{uid} — auth-linked identity + role gate for the whole app.
    // Anyone signed in can read (display-name lookups on opportunities/
    // applications); only the owner can write, and role/email/createdAt
    // are immutable after creation.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
        && unchanged('role')
        && unchanged('email')
        && unchanged('createdAt');
      // Self-deletion only, used by AccountSettings' Delete Account flow —
      // the client reauthenticates before this write, and it happens
      // alongside deleting the matching Firebase Auth account.
      allow delete: if isSelf(userId);

      // users/{uid}/bookmarks/{opportunityId} — one tiny doc per bookmark
      // (doc ID = opportunityId) rather than an array-in-doc, so a
      // collectionGroup query can answer "how many users bookmarked
      // opportunity X" — see the broader collectionGroup rule below.
      match /bookmarks/{opportunityId} {
        allow read, write: if isSelf(userId);
      }

      // users/{uid}/recently_viewed/{opportunityId} — a student's personal
      // view history, doc ID = opportunityId so re-viewing just bumps the
      // timestamp. No collectionGroup use case here (unlike bookmarks),
      // so this stays owner-only with no broader read rule.
      match /recently_viewed/{opportunityId} {
        allow read, write: if isSelf(userId);
      }
    }

    // opportunities/{id} — postings browsed by every student, managed only
    // by the owning startup.
    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.startupId == request.auth.uid
        && userRole(request.auth.uid) == 'startup';
      allow update, delete: if isSignedIn()
        && resource.data.startupId == request.auth.uid;

      // Any signed-in student can bump viewCount by exactly 1 when opening
      // the detail screen — backs the "Most viewed" analytics chart. Scoped
      // tightly so a viewer can never touch any other field.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount == resource.data.viewCount + 1;
    }

    // applications/{id} — the join between a student and an opportunity,
    // now tracking a full status pipeline (applied -> screening ->
    // interview -> technicalAssessment -> offer -> accepted/rejected).
    // Strict stage-adjacency validation lives in the app (ApplicationController),
    // not here — these rules are the coarser security backstop: only the
    // right actor can write, and terminal states can't be reopened.
    match /applications/{applicationId} {
      allow read: if isSignedIn()
        && (resource.data.applicantId == request.auth.uid
            || resource.data.startupId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.applicantId == request.auth.uid
        && userRole(request.auth.uid) == 'student'
        && get(/databases/$(database)/documents/opportunities/$(request.resource.data.opportunityId)).data.isActive == true;

      // Startup: can move a non-terminal application through the pipeline
      // (or reject it) but can't touch the applicant's original content.
      allow update: if isSignedIn()
        && resource.data.startupId == request.auth.uid
        && resource.data.status != 'accepted'
        && resource.data.status != 'rejected'
        && unchanged('applicantId')
        && unchanged('opportunityId')
        && unchanged('coverLetter')
        && unchanged('appliedAt');

      // Applicant: can only respond to their own offer (accept or decline).
      allow update: if isSignedIn()
        && resource.data.applicantId == request.auth.uid
        && resource.data.status == 'offer'
        && (request.resource.data.status == 'accepted'
            || request.resource.data.status == 'rejected')
        && unchanged('opportunityId')
        && unchanged('startupId')
        && unchanged('coverLetter')
        && unchanged('appliedAt');

      allow delete: if false;
    }

    // startup_profiles/{id} — public-facing company info, separate from the
    // private users/ auth record so it can be read by anyone browsing.
    match /startup_profiles/{profileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && userRole(request.auth.uid) == 'startup';
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      // Self-deletion only, used by Delete Account.
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // bookmarks/{uid} — LEGACY array-in-doc shape, superseded by
    // users/{uid}/bookmarks/{opportunityId}. Kept read/write-able only so
    // BookmarkRemoteDatasource.migrateLegacyBookmarksIfNeeded can lift a
    // user's old data into the new subcollection on their next sign-in;
    // safe to delete this block once all users have migrated.
    match /bookmarks/{userId} {
      allow read, write: if isSelf(userId);
    }

    // Recursive-wildcard rule authorizing the startup analytics dashboard's
    // collectionGroup('bookmarks').where('opportunityId', ==) aggregate
    // count query. Aggregate counts never return document data to the
    // client — only the numeric count — so this only exposes "how many",
    // never who or which other opportunities a user bookmarked.
    match /{path=**}/bookmarks/{bookmarkId} {
      allow read: if isSignedIn();
    }

    // student_profiles/{id} — rich, publicly-readable student profile,
    // separate from the private users/ auth record (mirrors startup_profiles).
    // Verification badge is derived client-side from profile completeness,
    // not an admin-granted field, so no extra rule is needed for it.
    match /student_profiles/{profileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && userRole(request.auth.uid) == 'student';
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      // Self-deletion only, used by Delete Account.
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // conversations/{id} — 1:1 thread between a student and a startup.
    // Doc ID is deterministic (sorted participant UIDs joined with '_'),
    // not auto-generated, so participantIds is derivable from the ID itself;
    // the check below still guards against writes/reads by anyone else.
    match /conversations/{conversationId} {
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;

      allow delete: if false;

      // messages/{id} — immutable once sent; only a participant of the
      // parent conversation can read, and only the sender (who must also be
      // a participant) can create.
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        allow update, delete: if false;
      }
    }
  }
}
