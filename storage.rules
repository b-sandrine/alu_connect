rules_version = '2';

// NOT DEPLOYED YET — review before running `firebase deploy --only storage`.

service firebase.storage {
  match /b/{bucket}/o {

    // startup_logos/{profileId}.jpg — public read (shown on opportunity
    // cards/detail to any browsing student), write only by an authenticated
    // user uploading their own startup profile's logo.
    match /startup_logos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // profile_images/{fileName} — student profile photos. Public read,
    // write only by an authenticated user uploading their own photo.
    match /profile_images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // chat_images/{conversationId}/{fileName} — only the two participants
    // of the parent conversation may read or upload. Cross-service rule:
    // Storage Rules can read Firestore data via firestore.get() (verify
    // carefully — less common syntax than the rest of this ruleset).
    match /chat_images/{conversationId}/{fileName} {
      function isParticipant() {
        return request.auth != null
          && request.auth.uid in
             firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participantIds;
      }

      allow read: if isParticipant();
      allow write: if isParticipant()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // founder_photos/{profileId}/{fileName}, team_photos/{profileId}/{fileName},
    // startup_gallery/{profileId}/{fileName} — public read (shown on the
    // startup's public profile to any browsing student), write only by the
    // startup that owns the referenced startup_profiles/{profileId} doc.
    // Cross-service check, same pattern as chat_images below.
    function isProfileOwner(profileId) {
      return request.auth != null
        && request.auth.uid ==
           firestore.get(/databases/(default)/documents/startup_profiles/$(profileId)).data.ownerId;
    }

    match /founder_photos/{profileId}/{fileName} {
      allow read: if true;
      allow write: if isProfileOwner(profileId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /team_photos/{profileId}/{fileName} {
      allow read: if true;
      allow write: if isProfileOwner(profileId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /startup_gallery/{profileId}/{fileName} {
      allow read: if true;
      allow write: if isProfileOwner(profileId)
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
